{
  "name": "blog",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "react-router build",
    "create:draft": "node scripts/create-draft.ts",
    "cf-typegen": "wrangler types",
    "deploy": "npm run build && wrangler deploy",
    "dev": "react-router dev",
    "format": "prettier --write .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npm run cf-typegen",
    "preview": "npm run build && vite preview",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "typecheck": "npm run cf-typegen && react-router typegen && tsc -b"
  },
  "dependencies": {
    "@conform-to/react": "^1.19.4",
    "@conform-to/zod": "^1.19.4",
    "@epic-web/client-hints": "^1.3.9",
    "@giscus/react": "^3.1.0",
    "@mdx-js/react": "^3.1.1",
    "@mdx-js/rollup": "^3.1.1",
    "@nasa-gcn/remix-seo": "^2.0.1",
    "@radix-ui/react-slot": "^1.3.0",
    "@react-router/fs-routes": "^8.0.1",
    "@react-router/node": "^8.0.1",
    "@react-router/serve": "^8.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.4.2",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "highlight.js": "^11.11.1",
    "isbot": "^5.1.44",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^8.0.1",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-mdx-frontmatter": "^5.2.0",
    "spin-delay": "^2.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^3.25.75"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@cloudflare/vite-plugin": "^1.42.3",
    "@epic-web/config": "^3.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@react-router/dev": "^8.0.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "patch-package": "^8.0.0",
    "prettier": "^3.9.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.1.4",
    "tw-animate-css": "^1.3.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "wrangler": "^4.90.0"
  },
  "postinstall": "patch-package"
}
